<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="jp.educure.attendancemanagement.mapper.LeaveTypeMapper">
    <select id="findAll" resultType="LeaveType">
        SELECT *
        FROM leave_type
    </select>
    <select id="findById" parameterType="int" resultType="LeaveType">
        SELECT *
        FROM leave_type
        WHERE id = #{id}
    </select>
    <insert id="insert" parameterType="LeaveType">
        INSERT INTO leave_type
            (name)
        VALUES
            (#{name})
    </insert>
    <update id="update" parameterType="LeaveType">
        UPDATE leave_type
        SET name = #{name}
        WHERE id = #{id}
    </update>
    <delete id="delete" parameterType="int">
        DELETE FROM leave_type
        WHERE id = #{id}
    </delete>
</mapper>