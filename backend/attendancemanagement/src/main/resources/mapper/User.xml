<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="jp.educure.attendancemanagement.mapper.UserMapper">

    <select id="findAll" resultType="User">
        SELECT * FROM users
    </select>

        <select id="findById" parameterType="int" resultType="User">
        SELECT *
        FROM users
        WHERE id = #{id}
    </select>

    <select id="findByEmail" parameterType="string" resultType="User">
        SELECT *
        FROM users
        WHERE email = #{email}
    </select>
    <insert id="insert" parameterType="jp.educure.attendancemanagement.entity.User">
        INSERT INTO users (name, email, password, role_id, department_id)
        VALUES (#{name}, #{email}, #{password}, #{roleId}, #{departmentId})
    </insert>

    <update id="update" parameterType="jp.educure.attendancemanagement.entity.User">
        UPDATE users
        SET name = #{name},
            email = #{email},
            password = #{password},
            role_id = #{roleId},
            department_id = #{departmentId}
        WHERE id = #{id}
    </update>

    <delete id="delete" parameterType="int">
        DELETE FROM users
        WHERE id = #{id}
    </delete>

</mapper>